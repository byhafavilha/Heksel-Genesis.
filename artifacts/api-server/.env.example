# ═══════════════════════════════════════════════════════════════════════════════
#  HEKSEL GENESIS — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha com suas credenciais reais.
#  NUNCA faça commit do arquivo .env — ele já está no .gitignore.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Asaas (Pagamentos PIX) ────────────────────────────────────────────────────
#  Homologação (testes):  https://sandbox.asaas.com/api/v3
#  Produção (real):       https://www.asaas.com/api/v3
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

#  Seu token de acesso da API do Asaas.
#  Encontre em: Asaas Dashboard → Minha Conta → Integrações → Gerar Token
ASAAS_API_KEY=SEU_TOKEN_ASAAS_AQUI

# ── Printful (Produção e Envio) ───────────────────────────────────────────────
#  Token de acesso da API da Printful.
#  Encontre em: Printful Dashboard → Settings → API → Generate Token
PRINTFUL_API_KEY=SEU_TOKEN_PRINTFUL_AQUI

#  ID da sua loja na Printful (necessário se tiver múltiplas lojas).
#  Encontre em: Printful Dashboard → Stores → clique na loja → URL contém o ID
PRINTFUL_STORE_ID=SEU_STORE_ID_PRINTFUL_AQUI

# ── Printful – Variant IDs dos produtos ──────────────────────────────────────
#  O Variant ID identifica cada variação de produto (modelo + tamanho + cor)
#  cadastrada na sua conta Printful.
#  Encontre em: Printful Dashboard → Stores → Products → editar produto → Sync Variants
#  O ID aparece na URL ou na lista de variantes.

#  Moletom principal customizado:
PRINTFUL_VARIANT_MOLETOM=VARIANT_ID_DO_MOLETOM

#  Brinde — Chaveiro Heksel Genesis (deixe em branco se não usar):
PRINTFUL_VARIANT_CHAVEIRO=VARIANT_ID_DO_CHAVEIRO

#  Brinde — Adesivo Heksel Genesis (deixe em branco se não usar):
PRINTFUL_VARIANT_ADESIVO=VARIANT_ID_DO_ADESIVO

# ── Servidor ──────────────────────────────────────────────────────────────────
#  Porta do servidor Express (gerenciada automaticamente pelo Replit)
PORT=8080
NODE_ENV=development
